  "blocks": [
    {
      "id": "TB-3",
      "name": "Transmission Paiements",
      "description": "Bloc principal des données de paiements (détaillés 10.2, agrégés 10.4). Ne peut pas coexister avec TB-2 (G6.29).",
      "xPath": "/PaymentsReport",
      "cardinality": "0..1",
      "subFlows": ["10.2", "10.4"],
      "rules": ["G6.29"],
      "groups": [
        {
          "id": "TG-33",
          "name": "Période de transmission (Paiements)",
          "description": "Période couverte par la transmission des encaissements.",
          "xPath": "/PaymentsReport/ReportPeriod",
          "cardinality": "1..1",
          "subFlows": ["10.2", "10.4"],
          "fields": [
            {
              "id": "TT-89",
              "name": "Date début période (Paiements)",
              "description": "Date de début de la période de transmission des encaissements. Format AAAAMMJJ.",
