                {
                  "id": "TT-95",
                  "name": "Montant TVA paiement (détaillé)",
                  "description": "Montant TVA pour ce taux.",
                  "type": "MONTANT",
                  "maxLength": "19.2",
                  "cardinality": "1..1",
                  "mandatory": true,
                  "xPath": "/PaymentsReport/Invoice/TaxSubtotal/TaxAmount",
                  "btEquivalent": null,
                  "example": "200.00",
                  "rules": ["G1.14"],
                  "subFlows": ["10.2"]
                }
