              "type": "TEXTE",
              "maxLength": 8,
              "cardinality": "1..1",
              "mandatory": true,
              "xPath": "/PaymentsReport/ReportPeriod/EndDate",
              "btEquivalent": null,
              "example": "20260930",
              "rules": ["G1.09", "G1.36", "G6.25", "G7.43"],
              "tips": "G6.25 : fin > début. G7.43 : TT-90 < contrôle système, TT-3 > TT-90.",
              "subFlows": ["10.2", "10.4"]
            }
          ]
        },
        {
