{
  "rules": {
    "BR-1": {"description": "Une facture doit comporter un identifiant de spécification (BT-24).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-24"], "explanation": "L'identifiant de spécification indique quel profil de norme est utilisé. Sans lui, le système ne sait pas comment interpréter la facture."},
    "BR-2": {"description": "Un numéro de facture (BT-1) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-1"], "explanation": "Sans numéro, la facture est irrecevable. C'est l'identifiant unique de la transaction, imposé par l'article 242 nonies A du CGI."},
    "BR-3": {"description": "Une date d'émission (BT-2) doit être présente.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-2"], "explanation": "La date d'émission est obligatoire légalement. Elle sert à déterminer l'année pour la règle d'unicité BR-FR-CO-02."},
    "BR-4": {"description": "Un code de type de facture (BT-3) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-3"], "explanation": "Le code type indique s'il s'agit d'une facture (380), d'un avoir (381), d'un acompte (386), etc."},
    "BR-5": {"description": "Un code de devise (BT-5) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-5"], "explanation": "Toute facture doit indiquer sa devise. En France : EUR."},
    "BR-6": {"description": "Le nom du vendeur (BT-27) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-27"], "explanation": "Mention légale obligatoire."},
    "BR-7": {"description": "Le nom de l'acheteur (BT-44) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-44"], "explanation": "Mention légale obligatoire."},
    "BR-8": {"description": "L'adresse postale du vendeur (BG-5) doit être présente.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BG-5"], "explanation": "Mention légale obligatoire."},
    "BR-9": {"description": "L'adresse du vendeur doit contenir un code pays (BT-40).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-40"], "explanation": "ISO 3166-1 alpha-2, donnée minimale obligatoire."},
    "BR-10": {"description": "L'adresse de l'acheteur (BG-8) doit être présente.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BG-8"], "explanation": "Obligation légale et routage."},
    "BR-11": {"description": "L'adresse de l'acheteur doit contenir un code pays (BT-55).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-55"], "explanation": "ISO 3166-1 alpha-2."},
    "BR-12": {"description": "L'adresse électronique du vendeur (BT-34) doit être présente.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-34"], "explanation": "Indispensable au routage. En France : SIREN avec schemeID 0225."},
    "BR-13": {"description": "L'adresse électronique de l'acheteur (BT-49) doit être présente.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-49"], "explanation": "Indispensable au routage vers la PA ou le PPF."},
    "BR-14": {"description": "Le montant total TTC (BT-112) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-112"], "explanation": "Donnée financière principale."},
    "BR-15": {"description": "Le net à payer (BT-115) doit être présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-115"], "explanation": "Montant final après acomptes."},
    "BR-16": {"description": "Au moins une ligne (BG-25) obligatoire.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BG-25"], "explanation": "Une facture sans ligne n'a pas de sens."},
    "BR-17": {"description": "BT-59 (nom bénéficiaire) requis si BG-10 présent.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-59"], "explanation": "Si le paiement va à un tiers, son nom doit figurer."},
    "BR-21": {"description": "Chaque ligne doit avoir un identifiant (BT-126).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-126"], "explanation": "Numéro séquentiel de ligne."},
    "BR-22": {"description": "Chaque ligne doit avoir une quantité (BT-129).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-129"], "explanation": "Nombre d'unités facturées."},
    "BR-23": {"description": "Chaque ligne doit avoir un code unité de mesure (BT-130).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-130"], "explanation": "Code rec20 : C62=pièce, HUR=heure, etc."},
    "BR-24": {"description": "Chaque ligne doit avoir un montant net (BT-131).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-131"], "explanation": "Montant HT final de la ligne."},
    "BR-25": {"description": "Chaque ligne doit avoir un nom d'article (BT-153).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-153"], "explanation": "Désignation obligatoire (art. 242 nonies A 3°)."},
    "BR-26": {"description": "Chaque ligne doit avoir un prix unitaire net (BT-146).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-146"], "explanation": "Indispensable au calcul."},
    "BR-27": {"description": "BT-146 ne doit pas être négatif.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-146"], "explanation": "Les prix sont toujours positifs."},
    "BR-31": {"description": "Chaque remise document (BG-20) doit avoir un montant (BT-92).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-92"], "explanation": "Remise globale chiffrée."},
    "BR-36": {"description": "Chaque charge document (BG-21) doit avoir un montant (BT-99).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-99"], "explanation": "Frais supplémentaires chiffrés."},
    "BR-45": {"description": "Chaque ventilation TVA doit avoir une base (BT-116).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-116"], "explanation": "Montant HT taxable."},
    "BR-47": {"description": "Chaque ventilation TVA doit avoir un code TVA (BT-118).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-118"], "explanation": "S, Z, E, AE, K, G, O."},
    "BR-48": {"description": "Chaque ventilation TVA doit avoir un montant TVA (BT-117).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-117"], "explanation": "Montant calculé pour chaque taux/catégorie."},
    "BR-49": {"description": "BG-16 doit avoir un code moyen de paiement (BT-81).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-81"], "explanation": "Codifié : 30=virement, 48=carte, 49=prélèvement, etc."},
    "BR-52": {"description": "Chaque document justificatif (BG-24) doit avoir BT-122.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-122"], "explanation": "Identifiant du document joint."},
    "BR-57": {"description": "Chaque adresse de livraison (BG-15) doit avoir BT-80.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-80"], "explanation": "Code pays crucial pour la TVA."},
    "BR-62": {"description": "Vendeur : au moins BT-30, BT-31 ou BT-32.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-30", "BT-31", "BT-32"], "explanation": "Au moins un identifiant officiel."},
    "BR-63": {"description": "Acheteur : au moins BT-47 et/ou BT-48.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-47", "BT-48"], "explanation": "Au moins un identifiant officiel."},
    "BR-65": {"description": "BT-158 doit avoir un schéma de classification.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR", "fields": ["BT-158"], "explanation": "CPV, UNSPSC, etc."},
    "BR-CO-3": {"description": "BT-7 et BT-8 mutuellement exclusifs.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR-CO", "fields": ["BT-7", "BT-8"], "explanation": "Date d'exigibilité OU code d'exigibilité, pas les deux."},
    "BR-CO-4": {"description": "Chaque ligne doit avoir BT-151.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR-CO", "fields": ["BT-151"], "explanation": "Catégorie TVA par ligne."},
    "BR-CO-5": {"description": "BT-98 et BT-97 doivent être cohérents.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR-CO", "fields": ["BT-97", "BT-98"], "explanation": "Code et texte de remise cohérents."},
    "BR-S-9": {"description": "BT-117 = BT-116 × BT-119 (taux normal).", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR-S", "fields": ["BT-116", "BT-117", "BT-118", "BT-119"], "explanation": "Règle arithmétique TVA = base × taux."},
    "BR-CL-01": {"description": "BT-3 doit être un code UNTDID 1001.", "level": "Niveau 1 (EN 16931)", "severity": "Bloquant", "category": "BR-CL", "fields": ["BT-3"], "explanation": "Restreint en France par BR-FR-04."},
    "BR-FR-01": {"description": "SIREN vendeur (BT-30) OBLIGATOIRE avec schemeID 0002.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-30", "BT-30-1"], "explanation": "Identifiant légal de référence en France. 9 caractères."},
    "BR-FR-02": {"description": "BT-34 au format SIREN/SIREN_XXX avec schemeID 0225.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-34", "BT-34-1"], "explanation": "Adresse de routage e-invoicing."},
    "BR-FR-03": {"description": "Dates entre 2010-01-01 et 2099-12-31.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-2", "BT-7", "BT-9", "BT-26", "BT-72", "BT-73", "BT-74", "BT-134", "BT-135"], "explanation": "Anti-dates aberrantes."},
    "BR-FR-04": {"description": "Codes types autorisés : 380/389/393/501 (factures), 386/500 (acomptes), 384/471/472/473 (rectificatives), 261/262/381/396/502/503 (avoirs).", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-3"], "explanation": "La France restreint les codes UNTDID 1001."},
    "BR-FR-05": {"description": "3 notes obligatoires : PMT (40€ recouvrement), PMD (pénalités), AAB (escompte).", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-21", "BT-22"], "explanation": "Code de commerce L441-10."},
    "BR-FR-06": {"description": "PMD, PMT, AAB, TXD : une seule occurrence chacun.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-21"], "explanation": "Pas de doublons."},
    "BR-FR-07": {"description": "Codes sujets normés : ACC, AAI, ADN, SUR, ABL, CUS, BLU, BAR.", "level": "Niveau 2 (BR-FR)", "severity": "Recommandation", "category": "BR-FR", "fields": ["BT-21", "BT-22"], "explanation": "Chaque type d'info a son code."},
    "BR-FR-08": {"description": "BT-23 : B1/S1/M1/B2/S2/M2/S3/B4/S4/M4/S5/S6/B7/S7/B8/S8/M8.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-23"], "explanation": "Cadre de facturation obligatoire. B=biens, S=services, M=mixte."},
    "BR-FR-09": {"description": "BT-49 OBLIGATOIRE avec schemeID 0225.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-49"], "explanation": "Routage acheteur."},
    "BR-FR-14": {"description": "BG-15 données obligatoires dès 01/09/2027 si adresse différente.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant (2027)", "category": "BR-FR", "fields": ["BT-75", "BT-77", "BT-78", "BT-80"], "explanation": "Trajectoire cible."},
    "BR-FR-15": {"description": "Codes TVA France : S, Z, E, AE, K, G, O uniquement.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-118", "BT-151"], "explanation": "L et M = Espagne seulement."},
    "BR-FR-22": {"description": "BT-34 obligatoire pour autofacturation (389/261/500/501/502).", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-34"], "explanation": "Retour statuts cycle de vie."},
    "BR-FR-26": {"description": "ID privé schemeID 0224 : max 100 caractères.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-29", "BT-46"], "explanation": "Code de routage limité."},
    "BR-FR-27": {"description": "BG-32 : BT-160 ou EXT-FR-FE-159 requis.", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-160", "EXT-FR-FE-159"], "explanation": "Au moins un pour identifier l'attribut."},
    "BR-FR-28": {"description": "BG-32 : BT-161 XOR (EXT-FR-FE-160 + 161).", "level": "Niveau 2 (BR-FR)", "severity": "Bloquant", "category": "BR-FR", "fields": ["BT-161", "EXT-FR-FE-160", "EXT-FR-FE-161"], "explanation": "Modes exclusifs de valorisation."},
    "BR-FR-CO-02": {"description": "Unicité : BT-1 + année BT-2 + BT-30 unique.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-1", "BT-2", "BT-30"], "explanation": "Contrôle systématique de non-doublon.", "legalRef": "BOI-TVA-DECLA-30-20-20-10"},
    "BR-FR-CO-03": {"description": "Si BT-3=262, BT-12 et BG-14 obligatoires.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-3", "BT-12", "BG-14"], "explanation": "Avoir remise globale = contrat + période."},
    "BR-FR-CO-05": {"description": "Si BT-3 = avoir, BT-25 et BT-26 obligatoires.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-3", "BT-25", "BT-26"], "explanation": "Tout avoir doit référencer l'origine."},
    "BR-FR-CO-08": {"description": "Pour B4/S4/M4, BT-3 != 386/500/503.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-23", "BT-3"], "explanation": "Pas d'acompte en facture définitive."},
    "BR-FR-CO-09": {"description": "Pour B2/S2/M2 : BT-113=BT-112, BT-115=0.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-23", "BT-112", "BT-113", "BT-115"], "explanation": "Cohérence facture déjà payée."},
    "BR-FR-CO-10": {"description": "Pas deux IDs privés avec même schemeID.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-29", "BT-46", "BT-60"], "explanation": "SchemeID distinct par identifiant."},
    "BR-FR-CO-13": {"description": "SIREN AU (schemeID 0231) dans l'Annuaire PPF.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-29"], "explanation": "Vérification Assujetti Unique."},
    "BR-FR-CO-14": {"description": "Si AU, note TXD='MEMBRE_ASSUJETTI_UNIQUE'.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-21", "BT-22"], "explanation": "Mention obligatoire AU."},
    "BR-FR-CO-15": {"description": "Si AU, BG-11 + BT-63 obligatoires.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BG-11", "BT-63"], "explanation": "N° TVA de l'Assujetti Unique."},
    "BR-FR-CO-16": {"description": "Franchise : BT-118='E', BT-121='VATEX-FR-FRANCHISE'.", "level": "Niveau 2 (BR-FR-CO)", "severity": "Bloquant", "category": "BR-FR-CO", "fields": ["BT-118", "BT-121", "BT-32"], "explanation": "Micro-entrepreneurs en franchise."},
    "BR-FR-DEC-01": {"description": "Montants : 19 pos max, 2 déc max, séparateur=point.", "level": "Niveau 2 (BR-FR-DEC)", "severity": "Bloquant", "category": "BR-FR-DEC", "fields": ["BT-92", "BT-99", "BT-106", "BT-109", "BT-110", "BT-111", "BT-112", "BT-113", "BT-114", "BT-115", "BT-116", "BT-117", "BT-131"], "explanation": "Format montants."},
    "BR-FR-DEC-02": {"description": "Quantités : 19 pos max, 6 déc max.", "level": "Niveau 2 (BR-FR-DEC)", "severity": "Bloquant", "category": "BR-FR-DEC", "fields": ["BT-129", "BT-149"], "explanation": "Précision quantités."},
    "BR-FR-DEC-03": {"description": "Prix unitaires : 19 pos max, 8 déc max.", "level": "Niveau 2 (BR-FR-DEC)", "severity": "Bloquant", "category": "BR-FR-DEC", "fields": ["BT-146", "BT-147", "BT-148"], "explanation": "Max précision prix."},
    "BR-FR-DEC-04": {"description": "Taux TVA : 4 pos max, 2 déc max.", "level": "Niveau 2 (BR-FR-DEC)", "severity": "Bloquant", "category": "BR-FR-DEC", "fields": ["BT-96", "BT-103", "BT-119", "BT-152"], "explanation": "France : 20, 10, 5.5, 2.1."},
    "BR-FR-MAP-01": {"description": "Flux 1 : numéro facture tronqué à 20 car. (19+'T').", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-1", "BT-25"], "explanation": "Troncature automatique par la PA."},
    "BR-FR-MAP-10": {"description": "Si BT-80 présent, BG-15 complet dans flux 1. Champs manquants = '-'.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BG-15", "BT-75", "BT-77", "BT-78", "BT-80"], "explanation": "Adresse livraison complétée."},
    "BR-FR-MAP-14": {"description": "DOM/COM remplacés par FR dans flux 1/10.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-40", "BT-55", "BT-80"], "explanation": "GF/TF/GP/GY/MQ/YT/RE/BL/MF/PM => FR."},
    "BR-FR-MAP-15": {"description": "Flux 1 BT-24 = urn.cpro.gouv.fr:..#Base ou #Full.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-24"], "explanation": "Base=sans lignes, Full=avec lignes."},
    "BR-FR-MAP-17": {"description": "Troncature 255 car. pour champs texte flux 1.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-75", "BT-76", "BT-77"], "explanation": "Champs adresse tronqués."},
    "BR-FR-MAP-25": {"description": "Si BT-121 sans BT-120, texte auto-généré dans flux 1.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-120", "BT-121"], "explanation": "Texte VATEX automatique."},
    "BR-FR-MAP-27": {"description": "Si BT-120 sans BT-121, code 'NR' injecté dans flux 1.", "level": "Niveau 2 (BR-FR-MAP)", "severity": "Info (mapping auto)", "category": "BR-FR-MAP", "fields": ["BT-121"], "explanation": "NR = No Reference."},
    "BR-FR-MV-04": {"description": "Multi-vendeurs (B8/S8/M8) : EXT-FR-FE-168 obligatoire pour lignes GROUP si vendeur assujetti.", "level": "Niveau 2 (BR-FR-MV)", "severity": "Bloquant", "category": "BR-FR-MV", "fields": ["EXT-FR-FE-168"], "explanation": "ID TVA vendeur à la ligne pour multi-vendeurs."},
    "BR-FR-MV-05": {"description": "Multi-vendeurs : total HT GROUP = somme des lignes enfants.", "level": "Niveau 2 (BR-FR-MV)", "severity": "Bloquant", "category": "BR-FR-MV", "fields": ["BT-131", "EXT-FR-FE-162"], "explanation": "Contrôle arithmétique multi-vendeurs."},
    "BR-FR-MV-06": {"description": "Multi-vendeurs : EXT-FR-FE-167 obligatoire et identique au parent.", "level": "Niveau 2 (BR-FR-MV)", "severity": "Bloquant", "category": "BR-FR-MV", "fields": ["EXT-FR-FE-167"], "explanation": "SIREN vendeur à la ligne."},
    "BR-FR-MV-07": {"description": "Multi-vendeurs : BT-128 (AFL) obligatoire et identique au parent.", "level": "Niveau 2 (BR-FR-MV)", "severity": "Bloquant", "category": "BR-FR-MV", "fields": ["BT-128"], "explanation": "N° facture à la ligne."}
  }
}